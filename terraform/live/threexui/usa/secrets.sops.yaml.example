# Plaintext template for the usa panel credentials. Create the real, encrypted file:
#
#   cd terraform/live/threexui/usa
#   cp secrets.sops.yaml.example secrets.sops.yaml
#   $EDITOR secrets.sops.yaml            # fill in real values
#   sops --encrypt --in-place secrets.sops.yaml
#
# The .sops.yaml rule encrypts base_path/username/password/bootstrap_* with the repo age key.
# The encrypted secrets.sops.yaml IS committed; this .example stays plaintext.
#
# base_path = the panel's webBasePath (the obscured panel path). Treated as a secret.
# password  = the DESIRED (steady-state) admin password — the module rotates the panel to it
#             (applied write-only, never stored in state).
base_path: /CHANGEME/
username: CHANGEME-admin
password: CHANGEME-new-strong-password

# Bootstrap (first-run rotation only): the panel's CURRENT/old creds. For an already-running
# panel that is being IMPORTED, set username/password above to the panel's CURRENT admin creds
# (so the provider can authenticate) and leave manage_panel_user off until import is settled.
# Remove these two lines after the first successful apply.
bootstrap_username: admin
bootstrap_password: admin
