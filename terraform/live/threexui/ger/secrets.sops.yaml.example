# Plaintext template for the ger panel credentials. Create the real, encrypted file:
#
#   cd terraform/live/ger
#   cp secrets.sops.yaml.example secrets.sops.yaml
#   $EDITOR secrets.sops.yaml            # fill in real values
#   sops --encrypt --in-place secrets.sops.yaml
#
# The .sops.yaml creation rule for terraform/ encrypts base_path/username/password with the
# repo age key. The encrypted secrets.sops.yaml IS committed; this .example stays plaintext.
#
# base_path = the panel's webBasePath (the obscured panel path). Treated as a secret.
base_path: /CHANGEME/
username: CHANGEME-admin
password: CHANGEME-password
