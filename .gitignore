# --- Ansible ---
# The real inventory IS committed: IPs/DNS/topology are not secrets (public infra,
# hardened, internet-facing by design). Real secrets go to SOPS/ansible-vault, never
# the inventory.
ansible/roles/external/
*.retry

# --- SOPS / age private keys (NEVER in git) ---
*.agekey
*.age.key
age.key
.sops-age-key.txt

# --- Ansible Vault password ---
.vault-pass
.vault-password

# --- kubeconfig fetched from the node ---
kubernetes/kubeconfig/
ansible/kubeconfig/

# --- Terraform ---
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.backup
terraform/**/*.tfvars
!terraform/**/*.example.tfvars
**/.terraform.lock.hcl

# --- misc ---
*.swp
.DS_Store
