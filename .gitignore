# --- Ansible ---
# Keep the real inventory out of git by default (the IP is not a secret, but
# connection data may slip in). Commit hosts.example.ini.
ansible/inventory/hosts.ini
ansible/roles/external/
*.retry

# --- SOPS / age private keys (NEVER in git) ---
*.agekey
*.age.key
age.key
.sops-age-key.txt

# --- Ansible Vault password ---
.vault-pass
.vault-password

# --- kubeconfig fetched from the node ---
kubernetes/kubeconfig/
ansible/kubeconfig/

# --- Terraform ---
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.backup
terraform/**/*.tfvars
!terraform/**/*.example.tfvars
**/.terraform.lock.hcl

# --- misc ---
*.swp
.DS_Store
