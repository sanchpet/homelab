# Template for the SOPS-encrypted secret. The owner creates the real file:
#
#   cp secret.sops.yaml.example secret.sops.yaml
#   $EDITOR secret.sops.yaml                       # fill the two values
#   export SOPS_AGE_KEY_FILE=$HOME/.config/sops/age/keys.txt
#   sops --encrypt --in-place secret.sops.yaml     # uses the age key from .sops.yaml
#
# SUBSCRIPTION_URL — 3x-ui subscription covering the ger+usa inbounds (tokenized → secret).
# HC_PING_URL      — healthchecks.io ping URL for the dead-man relay.
apiVersion: v1
kind: Secret
metadata:
  name: vpn-watch-secret
  namespace: monitoring
stringData:
  SUBSCRIPTION_URL: "https://<3x-ui-host>/sub/<token>"
  HC_PING_URL: "https://hc-ping.com/<uuid>"
